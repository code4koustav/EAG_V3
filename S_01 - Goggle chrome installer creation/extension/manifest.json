{
  "manifest_version": 3,
  "name": "SummaryGo — Meaning & Summarize",
  "version": "1.1.0",
  "description": "Local Python-powered meanings for selections and extractive page summaries.",
  "action": {
    "default_title": "SummaryGo",
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "service_worker.js"
  },
  "permissions": ["contextMenus", "scripting", "activeTab", "storage", "windows"],
  "host_permissions": ["http://127.0.0.1:8765/*", "http://localhost:8765/*"],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
